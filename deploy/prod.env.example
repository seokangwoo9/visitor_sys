# Production environment for the TOE Visitor Management System.
#
# Copy this file to deploy/prod.env and fill in real values:
#   cp deploy/prod.env.example deploy/prod.env
#   nano deploy/prod.env
#
# deploy/prod.env is git-ignored and must NEVER be committed.

# --- Database ---
POSTGRES_DB=visitor_system
POSTGRES_USER=visitor_system
# Use a strong, unique password.
POSTGRES_PASSWORD=replace-with-a-secure-database-password

# --- Authentication ---
# Generate a secret, e.g.: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-secure-random-secret
# The public HTTPS URL visitors and admins use. This must be the address the
# browser sees, even when HTTPS is terminated by an upstream reverse proxy
# (Option A). Example: https://tms.company.com
BETTER_AUTH_URL=https://tms.example.com

# --- App port binding (Option A: host reverse proxy in front) ---
# APP_BIND controls which VM network interface the app port is published on.
# Set it to the VM's PRIVATE IP so only the host reverse proxy can reach the
# app (recommended). Leave as 0.0.0.0 to expose on all interfaces.
#   APP_BIND=192.168.10.20
APP_BIND=0.0.0.0
# Host port the app is published on (container always listens on 3000).
APP_PORT=3000

# --- Domain / HTTPS (Option B ONLY: in-VM Caddy overlay) ---
# These are used only when you run docker-compose.prod.https.yml so the VM
# obtains its own certificate. With Option A (host terminates HTTPS) they are
# ignored and can be left as-is.
DOMAIN=tms.example.com
# Let's Encrypt notification email; use a real inbox.
ACME_EMAIL=you@example.com

# --- Initial admin seed (one-off: docker compose exec app npm run auth:seed-admin) ---
ADMIN_SEED_NAME=System Administrator
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=replace-with-a-secure-admin-password
